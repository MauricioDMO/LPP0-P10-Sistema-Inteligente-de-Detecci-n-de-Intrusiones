# Copy to /etc/suricata-lab/gateway.env in the Debian VM.
# WAN_IF: interface connected to the university network.
# LAN_IF: interface connected to the TP-Link AP.

WAN_IF="__WAN_IF__"
LAN_IF="__LAN_IF__"

LAN_IP="192.168.50.1"
LAN_CIDR="192.168.50.1/24"
LAN_NET="192.168.50.0/24"

DHCP_START="192.168.50.50"
DHCP_END="192.168.50.200"
DHCP_LEASE="12h"

DNS_1="1.1.1.1"
DNS_2="8.8.8.8"

NFQUEUE_NUM="0"

PROJECT_LINK_DIR="/opt/suricata-lab"
RENDER_DIR="/etc/suricata-lab/rendered"
